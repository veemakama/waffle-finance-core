{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "strict": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/events/**/*",
    "src/services/recovery-service.ts",
    "src/utils/rpc-methods.ts",
    "src/utils/event-history.ts"
  ]
}
