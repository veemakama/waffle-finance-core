{
  "name": "@wafflefinance/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the WaffleFinance cross-chain bridge: Ethereum + Soroban HTLC clients, secret utilities, and a shared order state machine.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ethereum": {
      "import": "./dist/ethereum/index.js",
      "types": "./dist/ethereum/index.d.ts"
    },
    "./soroban": {
      "import": "./dist/soroban/index.js",
      "types": "./dist/soroban/index.d.ts"
    },
    "./secrets": {
      "import": "./dist/secrets/index.js",
      "types": "./dist/secrets/index.d.ts"
    },
    "./state-machine": {
      "import": "./dist/state-machine/index.js",
      "types": "./dist/state-machine/index.d.ts"
    },
    "./solana": {
      "import": "./dist/solana/index.js",
      "types": "./dist/solana/index.d.ts"
    },
    "./assets": {
      "import": "./dist/assets/index.js",
      "types": "./dist/assets/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./htlc-client": {
      "import": "./dist/htlc-client.js",
      "types": "./dist/htlc-client.d.ts"
    },
    "./ethereum/adapter": {
      "import": "./dist/ethereum/adapter.js",
      "types": "./dist/ethereum/adapter.d.ts"
    },
    "./soroban/adapter": {
      "import": "./dist/soroban/adapter.js",
      "types": "./dist/soroban/adapter.d.ts"
    },
    "./solana/adapter": {
      "import": "./dist/solana/adapter.js",
      "types": "./dist/solana/adapter.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:analyze": "tsc && npm run analyze",
    "analyze": "node scripts/analyze-bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^13.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
