{
  "root": true,
  "extends": ["@wafflefinance/eslint-config"],
  "overrides": [
    {
      "files": ["frontend/src/**/*.{ts,tsx}"],
      "extends": ["@wafflefinance/eslint-config/react"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off"
      }
    },
    {
      "files": ["frontend/src/components/**/*.{ts,tsx}"],
      "rules": {
        "max-lines": [
          "error",
          {
            "max": 450,
            "skipBlankLines": true,
            "skipComments": true
          }
        ],
        "max-statements": [
          "error",
          {
            "max": 80
          }
        ],
        "complexity": [
          "error",
          {
            "max": 20
          }
        ]
      }
    }
  ]
}
