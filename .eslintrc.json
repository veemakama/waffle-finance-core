{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "node": true,
    "es2022": true
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "prefer-const": "error",
    "no-var": "error",
    "no-console": "off",
    "eqeqeq": [
      "error",
      "always"
    ],
    "@typescript-eslint/consistent-type-imports": [
      "warn",
      {
        "prefer": "type-imports"
      }
    ]
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "*.js",
    "*.cjs"
  ],
  "overrides": [
    {
      "files": [
        "frontend/src/**/*.{ts,tsx}"
      ],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off"
      }
    },
    {
      "files": [
        "frontend/src/components/**/*.{ts,tsx}"
      ],
      "rules": {
        "max-lines": [
          "error",
          {
            "max": 450,
            "skipBlankLines": true,
            "skipComments": true
          }
        ],
        "max-statements": [
          "error",
          {
            "max": 80
          }
        ],
        "complexity": [
          "error",
          {
            "max": 20
          }
        ]
      }
    }
  ]
}
